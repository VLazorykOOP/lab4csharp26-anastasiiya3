    // ==================== ЗАВДАННЯ 1: КЛАС ATriangle (ДОПОВНЕНИЙ) ====================
    class ATriangle
    {
        // Захищені поля
        protected int a; // катет 1
        protected int b; // катет 2
        protected int c; // колір трикутника

        // Властивості
        public int A
        {
            get { return a; }
            set
            {
                if (value > 0)
                    a = value;
                else
                    throw new ArgumentException("Катет має бути додатним");
            }
        }

        public int B
        {
            get { return b; }
            set
            {
                if (value > 0)
                    b = value;
                else
                    throw new ArgumentException("Катет має бути додатним");
            }
        }

        public int Color
        {
            get { return c; }
            set { c = value; }
        }

        // Конструктор
        public ATriangle(int a, int b, int color)
        {
            this.a = a;
            this.b = b;
            this.c = color;
        }

        // Індексатор
        public int this[int index]
        {
            get
            {
                switch (index)
                {
                    case 0: return a;
                    case 1: return b;
                    case 2: return c;
                    default:
                        throw new IndexOutOfRangeException("Помилка: індекс має бути 0, 1 або 2");
                }
            }
            set
            {
                switch (index)
                {
                    case 0: a = value; break;
                    case 1: b = value; break;
                    case 2: c = value; break;
                    default:
                        throw new IndexOutOfRangeException("Помилка: індекс має бути 0, 1 або 2");
                }
            }
        }

        // Методи
        public void PrintSides()
        {
            double hypotenuse = Math.Sqrt(a * a + b * b);
            Console.WriteLine($"Катети: {a}, {b}, Гіпотенуза: {hypotenuse:F2}");
        }

        public double CalculatePerimeter()
        {
            double hypotenuse = Math.Sqrt(a * a + b * b);
            return a + b + hypotenuse;
        }

        public double CalculateArea()
        {
            return (a * b) / 2.0;
        }

        public bool IsIsosceles()
        {
            return a == b;
        }

        public bool IsValid()
        {
            return a > 0 && b > 0;
        }

        public void PrintInfo()
        {
            Console.WriteLine($"Трикутник: a={a}, b={b}, колір={c}, площа={CalculateArea():F2}, периметр={CalculatePerimeter():F2}, рівнобедрений={(IsIsosceles() ? "Так" : "Ні")}");
        }

        // Перевантаження операції ++ (збільшує a і b на 1)
        public static ATriangle operator ++(ATriangle t)
        {
            t.a++;
            t.b++;
            return t;
        }

        // Перевантаження операції -- (зменшує a і b на 1)
        public static ATriangle operator --(ATriangle t)
        {
            t.a--;
            t.b--;
            return t;
        }

        // Перевантаження true/false
        public static bool operator true(ATriangle t)
        {
            return t.IsValid();
        }

        public static bool operator false(ATriangle t)
        {
            return !t.IsValid();
        }

        // Перевантаження операції + (додає скаляр до a і b)
        public static ATriangle operator +(ATriangle t, int scalar)
        {
            t.a += scalar;
            t.b += scalar;
            return t;
        }
    }

    // ==================== ЗАВДАННЯ 2: КЛАС VectorDouble ====================
    class VectorDouble
    {
        // Захищені поля
        protected double[] FArray;
        protected uint num;
        protected int codeError;
        protected static uint num_vd;

        // Властивості
        public uint Size
        {
            get { return num; }
        }

        public int CodeError
        {
            get { return codeError; }
            set { codeError = value; }
        }

        public static uint VectorCount
        {
            get { return num_vd; }
        }

        // Індексатор
        public double this[int index]
        {
            get
            {
                if (index >= 0 && index < num)
                {
                    codeError = 0;
                    return FArray[index];
                }
                else
                {
                    codeError = -1;
                    return 0;
                }
            }
            set
            {
                if (index >= 0 && index < num)
                {
                    FArray[index] = value;
                    codeError = 0;
                }
                else
                {
                    codeError = -1;
                }
            }
        }

        // Конструктори
        public VectorDouble()
        {
            num = 1;
            FArray = new double[num];
            FArray[0] = 0;
            codeError = 0;
            num_vd++;
        }

        public VectorDouble(uint size)
        {
            num = size;
            FArray = new double[num];
            for (int i = 0; i < num; i++)
                FArray[i] = 0;
            codeError = 0;
            num_vd++;
        }

        public VectorDouble(uint size, double initValue)
        {
            num = size;
            FArray = new double[num];
            for (int i = 0; i < num; i++)
                FArray[i] = initValue;
            codeError = 0;
            num_vd++;
        }

        // Деструктор
        ~VectorDouble()
        {
            Console.WriteLine($"Деструктор VectorDouble: видалено вектор розміром {num}");
            num_vd--;
        }

        // Методи
        public void InputFromKeyboard()
        {
            Console.WriteLine($"Введіть {num} елементів вектора:");
            for (int i = 0; i < num; i++)
            {
                Console.Write($"Елемент [{i}]: ");
                if (double.TryParse(Console.ReadLine(), out double value))
                    FArray[i] = value;
                else
                    FArray[i] = 0;
            }
        }

        public void Print()
        {
            Console.Write("Vector: [");
            for (int i = 0; i < num; i++)
            {
                Console.Write(FArray[i]);
                if (i < num - 1) Console.Write(", ");
            }
            Console.WriteLine("]");
        }

        public void SetAllValues(double value)
        {
            for (int i = 0; i < num; i++)
                FArray[i] = value;
        }

        public static uint GetVectorCount()
        {
            return num_vd;
        }

        // Перевантаження операцій
        // + для двох векторів
        public static VectorDouble operator +(VectorDouble v1, VectorDouble v2)
        {
            uint size = Math.Min(v1.num, v2.num);
            VectorDouble result = new VectorDouble(size);
            for (int i = 0; i < size; i++)
                result[i] = v1[i] + v2[i];
            return result;
        }

        // + для вектора і скаляра
        public static VectorDouble operator +(VectorDouble v, double scalar)
        {
            VectorDouble result = new VectorDouble(v.num);
            for (int i = 0; i < v.num; i++)
                result[i] = v[i] + scalar;
            return result;
        }

        // - для двох векторів
        public static VectorDouble operator -(VectorDouble v1, VectorDouble v2)
        {
            uint size = Math.Min(v1.num, v2.num);
            VectorDouble result = new VectorDouble(size);
            for (int i = 0; i < size; i++)
                result[i] = v1[i] - v2[i];
            return result;
        }

        // - для вектора і скаляра
        public static VectorDouble operator -(VectorDouble v, double scalar)
        {
            VectorDouble result = new VectorDouble(v.num);
            for (int i = 0; i < v.num; i++)
                result[i] = v[i] - scalar;
            return result;
        }

        // * для двох векторів
        public static VectorDouble operator *(VectorDouble v1, VectorDouble v2)
        {
            uint size = Math.Min(v1.num, v2.num);
            VectorDouble result = new VectorDouble(size);
            for (int i = 0; i < size; i++)
                result[i] = v1[i] * v2[i];
            return result;
        }

        // * для вектора і скаляра
        public static VectorDouble operator *(VectorDouble v, double scalar)
        {
            VectorDouble result = new VectorDouble(v.num);
            for (int i = 0; i < v.num; i++)
                result[i] = v[i] * scalar;
            return result;
        }

        // / для двох векторів
        public static VectorDouble operator /(VectorDouble v1, VectorDouble v2)
        {
            uint size = Math.Min(v1.num, v2.num);
            VectorDouble result = new VectorDouble(size);
            for (int i = 0; i < size; i++)
                result[i] = v2[i] != 0 ? v1[i] / v2[i] : 0;
            return result;
        }

        // / для вектора і скаляра
        public static VectorDouble operator /(VectorDouble v, double scalar)
        {
            VectorDouble result = new VectorDouble(v.num);
            for (int i = 0; i < v.num; i++)
                result[i] = scalar != 0 ? v[i] / scalar : 0;
            return result;
        }

        // % для двох векторів
        public static VectorDouble operator %(VectorDouble v1, VectorDouble v2)
        {
            uint size = Math.Min(v1.num, v2.num);
            VectorDouble result = new VectorDouble(size);
            for (int i = 0; i < size; i++)
                result[i] = v2[i] != 0 ? v1[i] % v2[i] : 0;
            return result;
        }

        // % для вектора і скаляра
        public static VectorDouble operator %(VectorDouble v, double scalar)
        {
            VectorDouble result = new VectorDouble(v.num);
            for (int i = 0; i < v.num; i++)
                result[i] = scalar != 0 ? v[i] % scalar : 0;
            return result;
        }

        // == та !=
        public static bool operator ==(VectorDouble v1, VectorDouble v2)
        {
            if (v1.num != v2.num) return false;
            for (int i = 0; i < v1.num; i++)
                if (Math.Abs(v1[i] - v2[i]) > 1e-9)
                    return false;
            return true;
        }

        public static bool operator !=(VectorDouble v1, VectorDouble v2)
        {
            return !(v1 == v2);
        }

        // >, >=, <, <=
        public static bool operator >(VectorDouble v1, VectorDouble v2)
        {
            uint size = Math.Min(v1.num, v2.num);
            for (int i = 0; i < size; i++)
                if (v1[i] <= v2[i])
                    return false;
            return true;
        }

        public static bool operator >=(VectorDouble v1, VectorDouble v2)
        {
            uint size = Math.Min(v1.num, v2.num);
            for (int i = 0; i < size; i++)
                if (v1[i] < v2[i])
                    return false;
            return true;
        }

        public static bool operator <(VectorDouble v1, VectorDouble v2)
        {
            uint size = Math.Min(v1.num, v2.num);
            for (int i = 0; i < size; i++)
                if (v1[i] >= v2[i])
                    return false;
            return true;
        }

        public static bool operator <=(VectorDouble v1, VectorDouble v2)
        {
            uint size = Math.Min(v1.num, v2.num);
            for (int i = 0; i < size; i++)
                if (v1[i] > v2[i])
                    return false;
            return true;
        }
    }

