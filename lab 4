            Console.WriteLine($"Трикутник існує: {(triangle ? "Так" : "Ні")}");
            ATriangle invalidTriangle = new ATriangle(-1, 2, 1);
            Console.WriteLine($"Неправильний трикутник існує: {(invalidTriangle ? "Так" : "Ні")}");

            // ========== ТЕСТУВАННЯ VectorDouble ==========
            Console.WriteLine("\n\n=== 2. ТЕСТУВАННЯ КЛАСУ VectorDouble ===\n");

            VectorDouble v1 = new VectorDouble(3, 2.5);
            VectorDouble v2 = new VectorDouble(3, 1.5);
            Console.WriteLine("Вектор v1:");
            v1.Print();
            Console.WriteLine("Вектор v2:");
            v2.Print();

            // Тестування арифметичних операцій
            Console.WriteLine("\n--- Арифметичні операції ---");
            VectorDouble v3 = v1 + v2;
            Console.Write("v1 + v2 = ");
            v3.Print();

            VectorDouble v4 = v1 - v2;
            Console.Write("v1 - v2 = ");
            v4.Print();

            VectorDouble v5 = v1 * v2;
            Console.Write("v1 * v2 = ");
            v5.Print();

            VectorDouble v6 = v1 / v2;
            Console.Write("v1 / v2 = ");
            v6.Print();

            // Тестування операцій зі скаляром
            Console.WriteLine("\n--- Операції зі скаляром ---");
            VectorDouble v7 = v1 + 5.0;
            Console.Write("v1 + 5 = ");
            v7.Print();

            // Тестування порівнянь
            Console.WriteLine("\n--- Порівняння векторів ---");
            Console.WriteLine($"v1 == v2: {v1 == v2}");
            Console.WriteLine($"v1 > v2: {v1 > v2}");
            Console.WriteLine($"v1 < v2: {v1 < v2}");

            Console.WriteLine($"\nКількість векторів VectorDouble: {VectorDouble.GetVectorCount()}");

            // ========== ТЕСТУВАННЯ VectorByte ==========
            Console.WriteLine("\n\n=== 3. ТЕСТУВАННЯ КЛАСУ VectorByte ===\n");

            VectorByte vb1 = new VectorByte(4, 5);
            VectorByte vb2 = new VectorByte(4, 3);
            Console.WriteLine("VectorByte vb1:");
            vb1.Print();
            Console.WriteLine("VectorByte vb2:");
            vb2.Print();

            // Тестування арифметичних операцій
            Console.WriteLine("\n--- Арифметичні операції ---");
            VectorByte vb3 = vb1 + vb2;
            Console.Write("vb1 + vb2 = ");
            vb3.Print();

            VectorByte vb4 = vb1 * vb2;
            Console.Write("vb1 * vb2 = ");
            vb4.Print();

            // Тестування побітових операцій
            Console.WriteLine("\n--- Побітові операції ---");
            VectorByte vb5 = vb1 | vb2;
            Console.Write("vb1 | vb2 = ");
            vb5.Print();

            VectorByte vb6 = vb1 & vb2;
            Console.Write("vb1 & vb2 = ");
            vb6.Print();

            // Тестування унарних операцій
            Console.WriteLine("\n--- Унарні операції ---");
            VectorByte vb7 = ++vb1;
            Console.Write("++vb1 = ");
            vb7.Print();

            VectorByte vb8 = ~vb1;
            Console.Write("~vb1 = ");
            vb8.Print();

            // Тестування true/false та !
            Console.WriteLine("\n--- true/false та ! ---");
            VectorByte vb9 = new VectorByte(3, 1);
            Console.WriteLine($"vb9 (всі ненульові): {(vb9 ? "true" : "false")}");
            Console.WriteLine($"!vb9: {!vb9}");

            Console.WriteLine($"\nКількість векторів VectorByte: {VectorByte.GetVectorCount()}");

            // ========== ТЕСТУВАННЯ STRUCTURE Patient ==========
            Console.WriteLine("\n\n=== 4. ТЕСТУВАННЯ СТРУКТУРИ PATIENT ===\n");

            // Створення масиву пацієнтів
            List<Patient> patients = new List<Patient>
            {
                new Patient("Іваненко", "Іван", "Іванович", "вул. Київська, 5", "MC001", "SP001"),
                new Patient("Петренко", "Петро", "Петрович", "вул. Львівська, 12", "MC002", "SP002"),
                new Patient("Сидоренко", "Сидір", "Сидорович", "вул. Харківська, 8", "MC003", "SP003"),
                new Patient("Коваленко", "Марія", "Олексіївна", "вул. Одеська, 3", "MC004", "SP004")
            };

            Console.WriteLine("Список пацієнтів:");
            foreach (var p in patients)
                p.Print();

            // Видалення елемента із заданим номером медичної карти
            string cardToRemove = "MC003";
            int removedCount = patients.RemoveAll(p => p.MedicalCardNumber == cardToRemove);
            Console.WriteLine($"\nВидалено пацієнта з карткою {cardToRemove}: {(removedCount > 0 ? "Так" : "Ні")}");

            // Додавання 2 елементів на початок масиву
            Patient newPatient1 = new Patient("Шевченко", "Тарас", "Григорович", "вул. Чернігівська, 7", "MC005", "SP005");
            Patient newPatient2 = new Patient("Франко", "Іван", "Якович", "вул. Івано-Франківська, 10", "MC006", "SP006");
            
            patients.Insert(0, newPatient2);
            patients.Insert(0, newPatient1);

            Console.WriteLine("\nОновлений список пацієнтів (після додавання 2 на початок):");
            foreach (var p in patients)
                p.Print();

            Console.WriteLine("\n\n========== ТЕСТУВАННЯ ЗАВЕРШЕНО ==========");
        }
