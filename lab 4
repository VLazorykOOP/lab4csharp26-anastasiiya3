    // 1. ВАРІАНТ ЧЕРЕЗ СТРУКТУРИ
    public struct PatientStruct
    {
        public string FullName;
        public string Address;
        public int CardNumber;
        public string InsurancePolicy;

        public override string ToString()
        {
            return string.Format("[Struct] {0}: {1}, {2}", CardNumber, FullName, Address);
        }
    }

    // 2. ВАРІАНТ ЧЕРЕЗ КЛАСИ (Заміна record для старих версій C#)
