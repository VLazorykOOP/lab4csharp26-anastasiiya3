using System;

public class Triangle
{
    private double a; // катет
    private double b; // катет
    private string color; // колір

    // Конструктор
    public Triangle(double a, double b, string color)
    {
        this.a = a;
        this.b = b;
        this.color = color;
    }

    // Індексатор
    public object this[int index]
    {
        get
        {
            switch (index)
            {
                case 0:
                    return a;
                case 1:
                    return b;
                case 2:
                    return color;
                default:
                    throw new IndexOutOfRangeException("Неправильний індекс. Використовуйте 0 (a), 1 (b) або 2 (колір).");
            }
        }
        set
        {
            switch (index)
            {
                case 0:
                    if (value is double doubleValue)
                        a = doubleValue;
                    else
                        throw new ArgumentException("Значення для поля a має бути типу double.");
                    break;
                case 1:
                    if (value is double doubleValueB)
                        b = doubleValueB;
                    else
                        throw new ArgumentException("Значення для поля b має бути типу double.");
                    break;
                case 2:
                    if (value is string stringValue)
                        color = stringValue;
                    else
                        throw new ArgumentException("Значення для поля колір має бути типу string.");
                    break;
                default:
                    throw new IndexOutOfRangeException("Неправильний індекс. Використовуйте 0 (a), 1 (b) або 2 (колір).");
            }
        }
    }

    // Метод для обчислення гіпотенузи
    public double GetHypotenuse()
    {
        return Math.Sqrt(a * a + b * b);
    }

    // Виведення інформації
    public void PrintInfo()
    {
        Console.WriteLine($"Трикутник: a = {a}, b = {b}, колір = {color}, гіпотенуза = {GetHypotenuse():F2}");
    }
}

// Приклад використання
class Program
{
    static void Main()
    {
        Triangle triangle = new Triangle(3, 4, "червоний");

        // Доступ через індексатор
        Console.WriteLine(triangle[0]); // 3
        Console.WriteLine(triangle[1]); // 4
        Console.WriteLine(triangle[2]); // червоний

        // Зміна значень через індексатор
        triangle[0] = 5.0;
        triangle[1] = 12.0;
        triangle[2] = "синій";

        triangle.PrintInfo();

        // Спроба звернутися до невірного індексу
        try
        {
            Console.WriteLine(triangle[3]);
        }
        catch (IndexOutOfRangeException ex)
        {
            Console.WriteLine($"Помилка: {ex.Message}");
        }
    }
} 

using System;

namespace VectorLab
{
    // Клас Вектор дійсних чисел
    class VectorDouble
    {
        // Поля (захищені)
        protected double[] FArray;
        protected uint num;
        protected int codeError;
        protected static uint num_vd = 0; // Статичне поле - лічильник об'єктів

        // --- Конструктори ---

        // 1. Без параметрів (один елемент = 0)
        public VectorDouble()
        {
            num = 1;
            FArray = new double[num];
            FArray[0] = 0;
            codeError = 0;
            num_vd++;
        }

        // 2. З одним параметром (розмір, ініціалізація нулями)
        public VectorDouble(uint size)
        {
            num = size;
            FArray = new double[num];
            for (int i = 0; i < num; i++) FArray[i] = 0;
            codeError = 0;
            num_vd++;
        }

        // 3. Із двома параметрами (розмір та початкове значення)
        public VectorDouble(uint size, double initValue)
        {
            num = size;
            FArray = new double[num];
            for (int i = 0; i < num; i++) FArray[i] = initValue;
            codeError = 0;
            num_vd++;
        }

        // Деструктор
        ~VectorDouble()
        {
            Console.WriteLine("Об'єкт VectorDouble видалено з пам'яті.");
        }

        // --- Методи ---

        public void Input()
        {
            for (int i = 0; i < num; i++)
            {
                Console.Write($"Введіть елемент [{i}]: ");
                if (double.TryParse(Console.ReadLine(), out double val))
                    FArray[i] = val;
                else
                    FArray[i] = 0;
            }
        }

        public void Output()
        {
            for (int i = 0; i < num; i++) Console.Write($"{FArray[i]} ");
            Console.WriteLine();
        }

        public void SetValue(double val)
        {
            for (int i = 0; i < num; i++) FArray[i] = val;
        }

        public static uint GetNumVd() => num_vd;

        // --- Властивості ---

        public uint Size => num; // Повертає розмірність (лише читання)

        public int CodeError
        {
            get => codeError;
            set => codeError = value;
        }

        // --- Індексатор ---
        public double this[int index]
        {
            get
            {
                if (index < 0 || index >= num)
                {
                    codeError = -1;
                    return 0;
                }
                return FArray[index];
            }
            set
            {
                if (index < 0 || index >= num)
                    codeError = -1;
                else
                    FArray[index] = value;
            }
        }

        // --- Перевантаження операторів ---

        // Унарний ++
        public static VectorDouble operator ++(VectorDouble v)
        {
            for (int i = 0; i < v.num; i++) v.FArray[i]++;
            return v;
        }

        // Унарний --
        public static VectorDouble operator --(VectorDouble v)
        {
            for (int i = 0; i < v.num; i++) v.FArray[i]--;
            return v;
        }

        // Перевантаження true/false (існує, якщо розмір не 0 і всі елементи != 0)
        public static bool operator true(VectorDouble v)
        {
            if (v.num == 0) return false;
            foreach (double x in v.FArray) if (x == 0) return false;
            return true;
        }

        public static bool operator false(VectorDouble v)
        {
            if (v.num == 0) return true;
            foreach (double x in v.FArray) if (x == 0) return true;
            return false;
        }

        // Арифметичне додавання (вектор + вектор)
        public static VectorDouble operator +(VectorDouble v1, VectorDouble v2)
        {
            uint minSize = Math.Min(v1.num, v2.num);
            VectorDouble res = new VectorDouble(minSize);
            for (int i = 0; i < minSize; i++) res[i] = v1[i] + v2[i];
            return res;
        }

        // Арифметичне додавання (вектор + скаляр)
        public static VectorDouble operator +(VectorDouble v, double scalar)
        {
            VectorDouble res = new VectorDouble(v.num);
            for (int i = 0; i < v.num; i++) res[i] = v[i] + scalar;
            return res;
        }

        // Побітове АБО (через приведення до long)
        public static VectorDouble operator |(VectorDouble v1, VectorDouble v2)
        {
            uint minSize = Math.Min(v1.num, v2.num);
            VectorDouble res = new VectorDouble(minSize);
            for (int i = 0; i < minSize; i++)
                res[i] = (double)((long)v1[i] | (long)v2[i]);
            return res;
        }

        // Порівняння ==
        public static bool operator ==(VectorDouble v1, VectorDouble v2)
        {
            if (v1.num != v2.num) return false;
            for (int i = 0; i < v1.num; i++) if (v1[i] != v2[i]) return false;
            return true;
        }

        public static bool operator !=(VectorDouble v1, VectorDouble v2) => !(v1 == v2);

        // Порівняння > (поелементно)
        public static bool operator >(VectorDouble v1, VectorDouble v2)
        {
            uint len = Math.Min(v1.num, v2.num);
            for (int i = 0; i < len; i++) if (v1[i] <= v2[i]) return false;
            return true;
        }

        public static bool operator <(VectorDouble v1, VectorDouble v2)
        {
            uint len = Math.Min(v1.num, v2.num);
            for (int i = 0; i < len; i++) if (v1[i] >= v2[i]) return false;
            return true;
        }
    }

    // Головний клас програми
    class Program
    {
        static void Main(string[] args)
        {
            Console.OutputEncoding = System.Text.Encoding.UTF8;

            // Створення об'єктів різними конструкторами
            VectorDouble v1 = new VectorDouble(3, 10.0);
            VectorDouble v2 = new VectorDouble(3);
            
            Console.WriteLine("Введіть дані для другого вектора:");
            v2.Input();

            Console.WriteLine("\nВектор 1:");
            v1.Output();
            Console.WriteLine("Вектор 2:");
            v2.Output();

            // Перевірка операторів
            VectorDouble vSum = v1 + v2;
            Console.WriteLine("\nРезультат додавання (v1 + v2):");
            vSum.Output();

            v1++;
            Console.WriteLine("\nВектор 1 після ++:");
            v1.Output();

            // Перевірка індексатора та помилки
            Console.WriteLine($"\nЕлемент v1[0]: {v1[0]}");
            double errorTest = v1[99]; 
            if (v1.CodeError == -1)
            {
                Console.WriteLine("Помилка: Спроба звернення за межі масиву!");
                v1.CodeError = 0; // Скидання помилки
            }

            Console.WriteLine($"\nВсього створено векторів: {VectorDouble.GetNumVd()}");
            
            Console.WriteLine("\nНатисніть будь-яку клавішу для завершення...");
            Console.ReadKey();
        }
    }
}
using System;
